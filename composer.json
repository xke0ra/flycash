{
    "name": "flycash/flycash",
    "description": "FLY CASH v4 - Money Making Script",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "mobiledetect/mobiledetectlib": "^4.8",
        "monolog/monolog": "^3.0",
        "phpmailer/phpmailer": "^6.9",
        "robmorgan/phinx": "^0.16.12",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "FlyCash\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "phpstan analyse",
        "check": ["@test", "@analyse"]
    }
}
